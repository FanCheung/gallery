{
  "name": "gallery",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @gallery/web dev",
    "dev:server": "bun run --filter @gallery/server dev",
    "start:server": "bun run --filter @gallery/server start",
    "build": "bun run --filter @gallery/web build",
    "build:server": "bun run --filter @gallery/server build",
    "preview": "bun run --filter @gallery/web preview",
    "clean": "bun run --filter @gallery/web clean",
    "lint": "bun run --filter @gallery/web lint && bun run --filter @gallery/server lint"
  }
}
